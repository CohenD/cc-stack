# ──────────────────────────────────────────────────────────────────────────
# cc-stack environment
#
# Copy this file to `.env.local` and fill in the values.
#
# IMPORTANT: Claude Code expands ${VAR} inside .mcp.json from the environment
# of the shell that launched `claude` — it does NOT auto-read .env.local.
# So export these before launching, or just use the bundled launcher which
# sources .env.local for you:
#
#     npm run cc        # loads .env.local, then starts `claude`
#
# ──────────────────────────────────────────────────────────────────────────

# Google Developer Knowledge MCP (live docs search across Google's dev docs).
# Required for the `google-docs` MCP server to start. Without it, that one
# server is skipped; the others still work.
# Get a key: https://console.cloud.google.com/ → enable the Developer
# Knowledge API → create an API key.
GOOGLE_API_KEY=

# Local DuckDB database file used by the `duckdb` MCP server (read-write).
# Defaults to ./data/dev.duckdb if left unset.
DUCKDB_PATH=./data/dev.duckdb

# Anthropic API key — only needed if you build AI features in the app with
# the Vercel AI SDK (@ai-sdk/anthropic). Not required for Claude Code itself.
ANTHROPIC_API_KEY=
